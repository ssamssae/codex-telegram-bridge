# Copy to a private path such as ~/.config/telegram-agent-bridge.env.
# Do not commit the edited file.

TAB_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
TAB_CHAT_ID=123456789

# repl = visible Codex CLI sync with text/image/video/audio prompt delivery.
# exec = text-only one-shot codex exec backend.
TAB_BRIDGE_MODE=repl

# Codex command. Only codex is supported; non-Codex values are rejected.
TAB_AGENT=codex
TAB_AGENT_CMD=codex

# Optional display label for the first group-chat reply chunk (suppressed in private chats).
TAB_PREFIX=BOT
# Put TAB_PREFIX on its own first line.
TAB_PREFIX_LINE=0

# State contains Telegram polling offset and resumable thread ids.
TAB_STATE_DIR=~/.local/state/telegram-agent-bridge

# Codex process settings.
TAB_WORKDIR=~
TAB_WORKDIR_LOCK=1
TAB_TIMEOUT=600
TAB_TG_CHUNK=4096
TAB_TYPING_INTERVAL=4

# Local input surface. Write one prompt per line to this FIFO to use the same
# resumable thread from a terminal without scraping the Codex TUI.
TAB_LOCAL_INPUT=~/.local/state/telegram-agent-bridge/input.fifo

# REPL-mode external signal surface. A cron job, webhook receiver, task queue,
# or custom orchestrator can write one plain-text or JSON prompt line here.
# Set to 0/off to disable.
CRB_SIGNAL_PATH=~/.local/state/telegram-agent-bridge/input.fifo

# Foreground terminal convenience. Defaults to on only when stdin is a TTY.
# Set to 0 in service files if you want FIFO-only local input.
TAB_STDIN_INPUT=0

# Codex-specific options.
# Leave this off unless you understand the security tradeoff.
TAB_CODEX_DANGEROUS_BYPASS=0
TAB_CODEX_EXTRA_ARGS=

# REPL mode options. Start Codex with:
#   tmux -L codex new -s codex
#   codex
CRB_TMUX_SOCKET=codex
CRB_TMUX_SESSION=codex
CRB_TMUX_SUBMIT_KEY=Tab
CRB_IMAGE_MODE=repl
CRB_FLOW_MIRROR=1
# Mirror Codex's public reasoning summary (🧠 코덱스 사고) right after the final
# answer. Only the runtime-public summary is sent, never raw chain-of-thought.
CRB_REASONING_MIRROR=1
CRB_LONG_RUNNING_PROGRESS_SECONDS=0
CRB_TYPING_LIVENESS_SECONDS=10
CRB_APPROVAL_TTL_SECONDS=300

# Final-answer media attachments. If Codex answers with a local image/video/audio
# path under one of these roots, the bridge uploads the file to Telegram and
# hides the local path from Telegram text.
# CRB_ATTACHMENT_ROOTS=~/.local/state/telegram-agent-bridge:/tmp
CRB_MAX_ATTACHMENT_BYTES=52428800

# Optional audio transcription. The setup wizard writes this automatically when
# codex_audio_transcribe.py is available; --install-asr installs its deps.
# CRB_AUDIO_TRANSCRIBE_CMD='/path/to/codex_audio_transcribe.py {path}'

# ---------------------------------------------------------------------------
# Advanced settings (defaults shown; CRB_* overrides win over TAB_* fallbacks).

# Direct token/chat overrides and token file used when TAB_BOT_TOKEN is unset.
# CRB_BOT_TOKEN=
# CRB_CHAT_ID=
# CRB_TOKEN_FILE=~/.config/codex-telegram-bridge/token.json

# Node label, reply emoji, and state directory.
# CRB_NODE=codex
# CRB_EMOJI=🤖
# CRB_STATE_DIR=~/.local/state/codex-telegram-bridge

# Telegram chunking and long-poll timeout.
# CRB_TG_CHUNK=4096
# CRB_TG_POLL_TIMEOUT=2

# Codex binary and exec-mode timeout.
# CRB_CODEX_BIN=codex
# CRB_CODEX_TIMEOUT=600

# tmux binary and extra Enter presses after paste (REPL mode).
# CRB_TMUX_BIN=tmux
# CRB_TMUX_ENTER_COUNT=5

# Media helpers for video/audio prompts.
# CRB_FFMPEG_BIN=ffmpeg
# CRB_FFPROBE_BIN=ffprobe
# CRB_VIDEO_FRAME_COUNT=3

# Generated-image autosend: final answers that reference a freshly created
# local image under these roots get the file uploaded automatically.
# CRB_GENERATED_IMAGE_AUTOSEND=1
# CRB_GENERATED_IMAGE_ROOTS=<CRB_ATTACHMENT_ROOTS>
# CRB_GENERATED_IMAGE_WINDOW_SEC=1800

# BYO signal file for external orchestrators (see BYO Signal Contract).
# CRB_DIRECTIVE_SIGNAL_PATH=<state_dir>/received-directive.jsonl

# telegram_agent_bridge (exec backend) tmux fallbacks.
# TAB_AGENT_TMUX_SOCKET=codex
# TAB_AGENT_TMUX_SESSION=codex
# TAB_AGENT_TMUX_SUBMIT_KEY=Tab
# TAB_AGENT_TMUX_ENTER_COUNT=5

# Watchdog probe tuning.
# TAB_WATCHDOG_SETTLE_SECONDS=2
# TAB_WATCHDOG_STATUS=<state_dir>/watchdog.status

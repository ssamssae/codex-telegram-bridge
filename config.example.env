# Copy to a private path such as ~/.config/telegram-agent-bridge.env.
# Do not commit the edited file.

TAB_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
TAB_CHAT_ID=123456789

# codex is the complete resumable backend.
TAB_AGENT=codex
TAB_AGENT_CMD=codex

# Optional display label for the first Telegram reply chunk.
TAB_PREFIX=BOT
# Put TAB_PREFIX on its own first line.
TAB_PREFIX_LINE=0

# State contains Telegram polling offset and resumable thread ids.
TAB_STATE_DIR=~/.local/state/telegram-agent-bridge

# Agent process settings.
TAB_WORKDIR=~
TAB_TIMEOUT=600
TAB_TG_CHUNK=4096
TAB_TYPING_INTERVAL=4

# Local input surface. Write one prompt per line to this FIFO to use the same
# resumable thread from a terminal without scraping an agent TUI.
TAB_LOCAL_INPUT=~/.local/state/telegram-agent-bridge/input.fifo

# Foreground terminal convenience. Defaults to on only when stdin is a TTY.
# Set to 0 in service files if you want FIFO-only local input.
TAB_STDIN_INPUT=0

# Codex-specific options.
# Leave this off unless you understand the security tradeoff.
TAB_CODEX_DANGEROUS_BYPASS=0
TAB_CODEX_EXTRA_ARGS=

# Generic one-shot fallback example:
# TAB_AGENT=generic
# TAB_AGENT_CMD='my-agent --prompt {prompt}'
